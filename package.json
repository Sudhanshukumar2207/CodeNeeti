{
  "name": "codeneeti",
  "private": true,
  "version": "1.0.0",
  "description": "CodeNeeti Desktop Application",
  "author": "Sudhanshu Kumar",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.codeneeti.app",
    "productName": "CodeNeeti",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
